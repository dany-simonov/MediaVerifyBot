# ─────────────────────────────────────────────────────────────
# Источник v0.2.0 — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────────────

# Telegram Bot
BOT_TOKEN=your_telegram_bot_token
WEBHOOK_URL=                               # optional, leave empty for polling mode

# Internal API
API_BASE_URL=http://api:8000               # Docker service name
API_SECRET_KEY=change_me_to_random_string

# Database
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/mediaverifybot

# External APIs — At least one per media type recommended
# Image detection (primary)
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# Text AI detection
SAPLING_API_KEY=

# Audio deepfake detection
RESEMBLE_API_KEY=

# HuggingFace Inference API (fallback)
HF_API_TOKEN=

# Rate Limits
FREE_DAILY_LIMIT=3
PREMIUM_MONTHLY_LIMIT=100

# Video processing
MAX_VIDEO_DURATION_SECONDS=60
VIDEO_FRAME_SAMPLE_RATE=1

# ─────────────────────────────────────────────────────────────
# Web Platform (static site)
# ─────────────────────────────────────────────────────────────
# Update web/config.js with your production API URL:
# window.ISTOCHNIK_CONFIG = {
#   apiBase: 'https://your-api-domain.com',
#   botUrl: 'https://t.me/YourBotUsername'
# };
